CHARGEBEE_SITE=zoca
CHARGEBEE_API_KEY=live_xxx_replace_me
METABASE_BASESHEET_URL=https://metabase.zoca.ai/public/question/87763e8c-8084-442e-891a-df1b11e81b47.csv
INVOICES_CACHE_TTL=300

# Auto-injected by Vercel when you attach a Neon Postgres database:
DATABASE_URL=

# --- NextAuth (Google sign-in restricted to @zoca.com) ---
# Generate with: `openssl rand -base64 32`
NEXTAUTH_SECRET=
# Required for production (your Vercel URL). Local dev defaults to http://localhost:3000.
NEXTAUTH_URL=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- Vercel Cron warm-up ---
# Used by /api/cron/warm to verify the request came from Vercel.
# Vercel auto-injects this as `CRON_SECRET` when you wire up a cron job;
# you can also set it manually for local testing with curl -H "Authorization: Bearer ...".
CRON_SECRET=

# --- Active tickets in the Tickets column (Metabase public CSV) ---
# Default points at the production "Active Linear tickets by entity" question.
# Override only if you fork the question to a different one.
# METABASE_TICKETS_URL=https://metabase.zoca.ai/public/question/331e4835-e163-4981-877e-14592f71741d.csv
# Optional fetch timeout; defaults to 15 seconds.
# METABASE_TICKETS_TIMEOUT_MS=15000
